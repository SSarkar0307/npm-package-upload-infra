{
 "compilerOptions": {
 "target": "ES2021",
 "module": "node16",
 "moduleResolution": "node16",
 "lib": ["ES2021"],
 "declaration": true,
 "outDir": "dist",
 "rootDir": "src",
 "strict": true,
 "esModuleInterop": true,
 "skipLibCheck": true,
 "forceConsistentCasingInFileNames": true,
 "resolveJsonModule": true
 },
 "include": ["src"],
 "exclude": ["node_modules", "dist", "tests", "examples"]
}
