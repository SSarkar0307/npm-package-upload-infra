# --- AWS S3 (use a real bucket) ---
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# --- Kafka (from docker compose) ---
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=pdf-file-processing
KAFKA_DLQ=pdf-file-processing-dlq

# --- MongoDB (from docker compose) ---
MONGO_URL=mongodb://localhost:27017/pdf-worker-demo

# --- App ---
UPLOAD_TOKEN=dev-token
PORT=3000
